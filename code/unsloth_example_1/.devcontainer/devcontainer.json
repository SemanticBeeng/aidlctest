{
  "name": "Qwen3 Eval (RunPod GPU)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  // GPU passthrough — required for model inference
  "runArgs": ["--gpus", "all", "--shm-size=4g"],

  // Mount strategy:
  //   /buildcache  ← named volume for ALL build byproducts (.venv, pip, caches)
  //                  NEVER pollutes the project workspace
  //                  on RunPod, sync or recreate via network volume
  //   /data        ← named volume for datasets & models (not build byproducts)
  //                  on RunPod, replace with a network volume at pod creation
  "mounts": [
    "source=eval-buildcache,target=/buildcache,type=volume",
    "source=eval-datasets,target=/data,type=volume"
  ],

  "containerEnv": {
    // ── Build byproducts → /buildcache (named volume, never in workspace) ──
    "VENV_DIR": "/buildcache/venv",
    "PKG_CACHE_DIR": "/buildcache/pkg-cache",
    "PYTHONPYCACHEPREFIX": "/buildcache/pycache",
    "MYPY_CACHE_DIR": "/buildcache/mypy",
    "RUFF_CACHE_DIR": "/buildcache/ruff",

    // ── Datasets & models → /data volume (not build byproducts) ──
    "HF_HOME": "/data/huggingface",
    "TRANSFORMERS_CACHE": "/data/huggingface/hub",
    "EVAL_RESULTS_DIR": "/data/eval_results",

    // ── General ──
    // LLM-as-judge (default: local OpenAI-compatible endpoint such as vLLM)
    // Override at runtime if you prefer OpenAI-hosted judges.
    "DEEPEVAL_JUDGE_BASE_URL": "http://judgepodforedgeai:8000/v1",
    "DEEPEVAL_JUDGE_MODEL": "meta-llama/Meta-Llama-3-8B-Instruct",
    "DEEPEVAL_JUDGE_API_KEY": "local-vllm",

    // "OPENAI_API_KEY": "" — optional; DeepEval will use DEEPEVAL_JUDGE_API_KEY by default
    "PYTHONPATH": "/workspace"
  },

  "postCreateCommand": "bash .devcontainer/setup.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/buildcache/venv/bin/python",
        "python.terminal.activateEnvironment": true,
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false
    }
  }
}
