{
  "name": "Qwen3 Eval (RunPod GPU)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  // GPU passthrough — required for model inference
  "runArgs": ["--gpus", "all", "--shm-size=4g"],

  // Network volumes for persistent storage across pod restarts.
  // On RunPod, create two network volumes and mount them to /env and /data
  // when launching the pod. Inside the dev container, they appear at these paths.
  "mounts": [
    "source=eval-python-env,target=/env,type=volume",
    "source=eval-datasets,target=/data,type=volume"
  ],

  "containerEnv": {
    // Poetry virtualenvs stored on network volume — survives pod restarts
    "POETRY_VIRTUALENVS_PATH": "/env/virtualenvs",
    "PIP_CACHE_DIR": "/env/pip-cache",

    // HuggingFace cache on network volume — datasets downloaded once
    "HF_HOME": "/data/huggingface",
    "TRANSFORMERS_CACHE": "/data/huggingface/hub",

    // Eval results stored persistently
    "EVAL_RESULTS_DIR": "/data/eval_results",

    // OpenAI key for LLM-as-judge (set at pod launch or in .env)
    // "OPENAI_API_KEY": "" — set via RunPod secrets or env var
    "PYTHONPATH": "/workspace"
  },

  "postCreateCommand": "bash .devcontainer/setup.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/env/virtualenvs/qwen3-phone-deployment-py3.11/bin/python",
        "python.terminal.activateEnvironment": true,
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false
    }
  }
}
